{
  "name": "irgeztne-workspace",
  "version": "1.0.0-preview.1",
  "description": "IRGEZTNE Workspace is an early preview desktop workspace for browsing, writing, editing, and preparing web projects for future publishing.",
  "main": "main.js",
  "author": {
    "name": "Irgeztne",
    "email": "irgeztne@gmail.com"
  },
  "license": "MIT",
  "scripts": {
    "start": "electron . --no-sandbox",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:appimage": "electron-builder --linux AppImage",
    "dist:deb": "electron-builder --linux deb",
    "dist:linux": "electron-builder --linux deb AppImage --publish never",
    "dist:win": "electron-builder --win nsis --publish never",
    "dist:mac": "electron-builder --mac dmg --publish never"
  },
  "dependencies": {
    "jodit": "^4.12.2"
  },
  "devDependencies": {
    "electron": "41.3.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.irgeztne.workspace",
    "productName": "IRGEZTNE Workspace",
    "artifactName": "IRGEZTNE-Workspace-${version}.${ext}",
    "directories": {
      "output": "dist"
    },
    "files": [
      "assets/**/*",
      "data/**/*",
      "src/**/*",
      "templates/**/*",
      "index.html",
      "main.js",
      "preload.js",
      "renderer.js",
      "state.js",
      "styles.css",
      "package.json"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility",
      "maintainer": "Irgeztne <irgeztne@gmail.com>",
      "icon": "build/icon.png"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.developer-tools"
    }
  },
  "productName": "IRGEZTNE Workspace",
  "homepage": "https://github.com/Irgeztne/irgeztne-workspace",
  "repository": {
    "type": "git",
    "url": "https://github.com/Irgeztne/irgeztne-workspace.git"
  }
}
