{
  "name": "irgeztne-workspace",
  "version": "1.0.0-preview.1",
  "description": "IRGEZTNE Workspace v1 Preview",
  "main": "main.js",
  "author": {
    "name": "Irgeztne",
    "email": "irgeztne@gmail.com"
  },
  "license": "UNLICENSED",
  "scripts": {
    "start": "electron . --no-sandbox",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --linux AppImage deb",
    "dist:appimage": "electron-builder --linux AppImage",
    "dist:deb": "electron-builder --linux deb"
  },
  "dependencies": {
    "jodit": "^4.12.2"
  },
  "devDependencies": {
    "electron": "41.3.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.irgeztne.workspace",
    "productName": "IRGEZTNE Workspace",
    "artifactName": "IRGEZTNE-Workspace-${version}.${ext}",
    "directories": {
      "output": "dist"
    },
    "files": [
      "assets/**/*",
      "data/**/*",
      "src/**/*",
      "templates/**/*",
      "index.html",
      "main.js",
      "preload.js",
      "renderer.js",
      "state.js",
      "styles.css",
      "package.json"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility",
      "maintainer": "Irgeztne <irgeztne@gmail.com>"
    }
  }
}
